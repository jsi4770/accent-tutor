# Copy to .env and fill in. Never commit real secrets.

# Server
PORT=4000

# --- Future AI integrations (not wired yet; see service provider stubs) ---
# Anthropic API key for LLM-based expression recommendation (claude-*).
ANTHROPIC_API_KEY=

# Speech scoring provider key for real prosody/pronunciation analysis.
SPEECH_PROVIDER_API_KEY=

# --- Future auth ---
# Secret for signing real JWTs once mock auth is replaced.
JWT_SECRET=

# --- Google sign-in ---
# OAuth 2.0 "Web application" client from Google Cloud Console.
# GOOGLE_CLIENT_ID must match app/.env's EXPO_PUBLIC_GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_SECRET is server-only — never expose it to the app bundle.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
